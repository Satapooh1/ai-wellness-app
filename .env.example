# --- Server-side (Vercel Serverless Functions / local Express) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_HEALTH_MODEL=gpt-4o

# --- Frontend (Vite) ---
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_OPENAI_MODEL=gpt-4o
VITE_ENABLE_DIRECT_OPENAI=false

# Local dev only — set to http://127.0.0.1:3001 to use local Express server
# Leave BLANK on Vercel (frontend will use relative /api/... path)
VITE_AGENT_SERVER=http://127.0.0.1:3001
